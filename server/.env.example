# === Bnovo PMS API ===
# Получить токен: https://pms.bnovo.ru/api/v1/
BNOVO_API_TOKEN=your_bnovo_api_token_here

# ID номеров/типов в Bnovo (указать реальные из ЛК Bnovo)
BNOVO_ROOM_4P_ID=123
BNOVO_ROOM_8P_ID=456
BNOVO_PROPERTY_ID=789

# === ЮKassa API ===
# Получить в личном кабинете: https://yookassa.ru
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here

# === Сервер ===
PORT=3000
FRONTEND_URL=https://overlynxxx.github.io/trava

# === Bnovo Endpoint ===
BNOVO_BASE_URL=https://api.bnovo.ru

# === ЮKassa Endpoint ===
YOOKASSA_BASE_URL=https://api.yookassa.ru/v3

# === Webhook Secret (генерируется автоматически) ===
# Используется для проверки подписи callback от ЮKassa
# YOOKASSA_WEBHOOK_SECRET=auto_generated
